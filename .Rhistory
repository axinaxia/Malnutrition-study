as.data.frame()
# View(nutri_attr_cov)
nutri<-read_dta("Malnutrition and HCRU SNACK.dta") %>%
as.data.frame()
# Medical history interview
med_hist_w1<-read_sav("diagnosis and anamnesis wave 1-3/wave 1/SNAC-K wave 1 anamnesis clean.sav") %>%
as.data.frame()
