filter(dup_record==0&klin!="") %>%
select(-c(INDATUMA)) %>%
distinct(lopnr,klin, mott,spec,bdat,.keep_all = T) %>%
right_join(attri %>% select(lopnr,date1,pv_fu_date_max)) %>%
filter(pv_date>=date1&pv_date<=pv_fu_date_max)
