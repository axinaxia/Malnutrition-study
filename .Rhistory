as.data.frame()
phy_diag_w2<-read_sav("diagnosis and anamnesis wave 1-3/wave 2/SNAC-K 14 DIAGNOS follow-up wave 2 clean.sav") %>%
as.data.frame()
phy_diag_w3<-read_sav("diagnosis and anamnesis wave 1-3/wave 3/SNAC-K diagnosis wave 3.sav") %>%
as.data.frame()
phy_diag_w3<-read_sav("diagnosis and anamnesis wave 1-3/wave 3/SNAC-K 14 ICD-diagnosis follow-up wave 3 clean.sav") %>%
as.data.frame()
# nurse interview on smell, ADL, etc
nurse_int_w1<-read_sav("Nurse wave 1-3/wave1/SNAC-K nurse wave1.sav") %>%
as.data.frame()
nurse_int_w2<-read_sav("Nurse wave 1-3/wave2/SNAC-K nurse wave 2 follow-up .sav") %>%
as.data.frame()
nurse_int_w3<-read_sav("Nurse wave 1-3/wave3/SNAC-K nurse wave 3 follow-up.sav") %>%
as.data.frame()
# death information collected by SNAC-K coordinator
death<-read_sav("SNAC-K c1 c2 death date from coordinator.sav") %>%
as.data.frame()
View(death)
View(death %>% filter(is.na(dödsdatum_f7)))
View(death)
