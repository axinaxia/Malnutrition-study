as.data.frame()
val_2001_2012<-val_2001_2012 %>%
mutate(year=as.numeric(substr(bdat,1,4)))
# View(val_2001_2012)
# Outpatient care from NPR between 2017-2023
ov_after2016<-read_sav("npr and val/PAR_OV_2017-2023_C1_C2.sav") %>%
as.data.frame()
# View(ov_after2016)
